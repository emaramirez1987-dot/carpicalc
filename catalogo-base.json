        { "id": "cajones_int", "nombre": "Cajones interiores", "tipo": "integer", "def": 2, "min": 0, "max": 4 },
        { "id": "estantes_int","nombre": "Estantes zona izquierda", "tipo": "integer", "def": 3, "min": 1, "max": 5 }
      ],
      "zonas": [
        { "id": "cuerpo", "nombre": "Cuerpo",        "material": "melamina", "espesor": 18 },
        { "id": "frente", "nombre": "Frente puertas","material": "melamina", "espesor": 18 }
      ],
      "constraints": [
        { "expr": "ancho >= 1500", "msg": "El placar 3 puertas requiere al menos 1500 mm" }
      ],
      "piezas": [
        { "nombre": "Lateral Izq.",        "cantidad": 1, "zona": "cuerpo", "orientacion3d": "vertical",   "formula1": "alto",            "formula2": "profundidad",      "posFormulas": { "x": "0",                       "y": "0",                                            "z": "0" } },
        { "nombre": "Lateral Der.",        "cantidad": 1, "zona": "cuerpo", "orientacion3d": "vertical",   "formula1": "alto",            "formula2": "profundidad",      "posFormulas": { "x": "ancho - esp",             "y": "0",                                            "z": "0" } },
        { "nombre": "Divisor vertical",    "cantidad": 1, "zona": "cuerpo", "orientacion3d": "vertical",   "formula1": "alto - 2 * esp",  "formula2": "profundidad",      "posFormulas": { "x": "ancho * 2 / 3",           "y": "esp",                                          "z": "0" } },
        { "nombre": "Base",                "cantidad": 1, "zona": "cuerpo", "orientacion3d": "horizontal", "formula1": "ancho - 2 * esp", "formula2": "profundidad",      "posFormulas": { "x": "esp",                     "y": "0",                                            "z": "0" } },
        { "nombre": "Techo",               "cantidad": 1, "zona": "cuerpo", "orientacion3d": "horizontal", "formula1": "ancho - 2 * esp", "formula2": "profundidad",      "posFormulas": { "x": "esp",                     "y": "alto - esp",                                   "z": "0" } },
        { "nombre": "Fondo",               "cantidad": 1, "zona": "cuerpo", "orientacion3d": "frente",     "formula1": "alto",            "formula2": "ancho",            "posFormulas": { "x": "0",                       "y": "0",                                            "z": "0" } },
        { "nombre": "Estante izq #{i}",    "cantidad": 1, "zona": "cuerpo", "orientacion3d": "horizontal", "formula1": "ancho * 2 / 3 - 2 * esp", "formula2": "profundidad - 20", "posFormulas": { "x": "esp",            "y": "i * (alto / (estantes_int + 1))",              "z": "0" }, "repeat": { "var": "i", "from": 1, "to": "estantes_int" } },
        { "nombre": "Frente cajon #{i}",   "cantidad": 1, "zona": "frente", "orientacion3d": "frente",     "formula1": "alto_cajon_int - 4", "formula2": "ancho / 3 - 4", "posFormulas": { "x": "ancho * 2 / 3 + 2",       "y": "(i - 1) * alto_cajon_int + esp + 2",           "z": "profundidad" }, "repeat": { "var": "i", "from": 1, "to": "cajones_int" } },
        { "nombre": "Puerta Izq.",         "cantidad": 1, "zona": "frente", "orientacion3d": "frente",     "formula1": "alto - 4",        "formula2": "ancho / 3 - 3",    "posFormulas": { "x": "2",                       "y": "2",                                            "z": "profundidad" } },
        { "nombre": "Puerta Centro",       "cantidad": 1, "zona": "frente", "orientacion3d": "frente",     "formula1": "alto - 4",        "formula2": "ancho / 3 - 3",    "posFormulas": { "x": "ancho / 3 + 1",           "y": "2",                                            "z": "profundidad" } },
        { "nombre": "Puerta Der. (sup)",   "cantidad": 1, "zona": "frente", "orientacion3d": "frente",     "formula1": "alto - alto_zona_cajones - 4", "formula2": "ancho / 3 - 3", "posFormulas": { "x": "ancho * 2 / 3 + 1", "y": "alto_zona_cajones + 2",                       "z": "profundidad" }, "condition": "cajones_int > 0" },
        { "nombre": "Puerta Der.",         "cantidad": 1, "zona": "frente", "orientacion3d": "frente",     "formula1": "alto - 4",        "formula2": "ancho / 3 - 3",    "posFormulas": { "x": "ancho * 2 / 3 + 1",       "y": "2",                                            "z": "profundidad" }, "condition": "cajones_int == 0" }
      ],
      "herrajes": [
        { "id": 1, "cantidad": "cajones_int > 0 ? 8 : 6" },
        { "id": 2, "cantidad": "cajones_int * 2" },
        { "id": 3, "cantidad": "cajones_int + 3" }
      ],
      "moDeObra": { "tipo": "por_modulo", "horas": 0 },
      "imagen": null,
      "subComponentes": []
    },

