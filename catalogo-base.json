    "BA003": {
      "nombre": "Bajo con cajones",
      "descripcion": "Bajo con cantidad variable de cajones (2 a 5). Los cajones se distribuyen automaticamente.",
      "categoria": "bajos",
      "material": "melamina",
      "tipoVisual": "bajo",
      "dimensiones": { "ancho": 600, "alto": 720, "profundidad": 550 },
      "variables": {
        "alto_cajon": "(alto - 2 * esp) / cajones"
      },
      "parametros": [
        { "id": "cajones", "nombre": "Cantidad de cajones", "tipo": "integer", "def": 3, "min": 2, "max": 5 }
      ],
      "zonas": [
        { "id": "cuerpo", "nombre": "Cuerpo", "material": "melamina", "espesor": 18 },
        { "id": "frente", "nombre": "Frente", "material": "mdf", "espesor": 18 }
      ],
      "constraints": [
        { "expr": "alto >= cajones * 100", "msg": "El alto debe ser al menos 100 mm por cajon" },
        { "expr": "ancho >= 300", "msg": "El ancho minimo recomendado es 300 mm" }
      ],
      "piezas": [
        { "nombre": "Lateral Izq.",      "cantidad": 1, "zona": "cuerpo", "orientacion3d": "vertical",   "formula1": "alto",                        "formula2": "profundidad",   "posFormulas": { "x": "0",             "y": "0",                                  "z": "0" } },
        { "nombre": "Lateral Der.",      "cantidad": 1, "zona": "cuerpo", "orientacion3d": "vertical",   "formula1": "alto",                        "formula2": "profundidad",   "posFormulas": { "x": "ancho - esp",   "y": "0",                                  "z": "0" } },
        { "nombre": "Base",              "cantidad": 1, "zona": "cuerpo", "orientacion3d": "horizontal", "formula1": "ancho - 2 * esp",             "formula2": "profundidad",   "posFormulas": { "x": "esp",           "y": "0",                                  "z": "0" } },
        { "nombre": "Techo",             "cantidad": 1, "zona": "cuerpo", "orientacion3d": "horizontal", "formula1": "ancho - 2 * esp",             "formula2": "profundidad",   "posFormulas": { "x": "esp",           "y": "alto - esp",                         "z": "0" } },
        { "nombre": "Fondo",             "cantidad": 1, "zona": "cuerpo", "orientacion3d": "frente",     "formula1": "alto",                        "formula2": "ancho",         "posFormulas": { "x": "0",             "y": "0",                                  "z": "0" } },
        { "nombre": "Frente cajon #{i}", "cantidad": 1, "zona": "frente", "orientacion3d": "frente",     "formula1": "alto_cajon - 4",              "formula2": "ancho - 4",     "posFormulas": { "x": "2",             "y": "(i - 1) * alto_cajon + esp + 2",     "z": "profundidad" },  "repeat": { "var": "i", "from": 1, "to": "cajones" } }
      ],
      "herrajes": [
        { "id": 2, "cantidad": "cajones * 2" },
        { "id": 3, "cantidad": "cajones" }
      ],
      "moDeObra": { "tipo": "por_modulo", "horas": 0 },
      "imagen": null,
      "subComponentes": []
    },

